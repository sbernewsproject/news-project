# Remote server with Ollama + Qwen
OLLAMA_URL=http://YOUR_SERVER_IP:11434
OLLAMA_MODEL=qwen2.5:32b

# Local Qdrant (Docker)
QDRANT_URL=http://localhost:6333

# Local Postgres (Docker)
POSTGRES_DSN=postgresql://news:news@localhost:5432/newsdb

# Where LightRAG stores the knowledge graph on disk
GRAPH_WORKING_DIR=./ragu_working_dir