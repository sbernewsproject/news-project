# Remote server with Ollama + Qwen
OLLAMA_URL=http://YOUR_SERVER_IP:11434
OLLAMA_MODEL=qwen3.5:32b
# Эмбеддинг-модель в Ollama для семантической части гибридного поиска (/api/articles?q=)
OLLAMA_EMBED_MODEL=bge-m3

# RAG-сервис на GPU-хосте: лёгкий API на VPS проксирует сюда POST /query.
# Если не задан — /query пытается поднять RAG локально (нужен тяжёлый образ с моделями).
RAG_URL=http://YOUR_GPU_HOST_IP:8001

# Local Qdrant (Docker)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=password

# Local Postgres (Docker)
POSTGRES_DSN=postgresql://user:password@localhost:5432/mydb

GRAPH_WORKING_DIR=./ragu_working_dir

# Локальные пути к моделям (если скачаны вручную)
BGE_MODEL_PATH=~/.cache/huggingface/hub/bge-m3-local
RERANKER_MODEL_PATH=~/.cache/huggingface/hub/bge-reranker-local